# Backend API Configuration with Failover Support
# This file documents all available environment variables for the frontend.
# Copy this to .env or use with .env.development / .env.production

# ============================================================================
# PRIMARY BACKEND (Required)
# ============================================================================
# Main backend API URL that will be used for all requests
# Must include /api path if your backend uses it
VITE_PRIMARY_API_URL=http://127.0.0.1:8000/api

# ============================================================================
# SECONDARY BACKEND (Optional)
# ============================================================================
# Backup backend URL for automatic failover
# If configured, requests to PRIMARY will automatically retry on SECONDARY if:
#   - Network error or timeout occurs
#   - Server returns 502 Bad Gateway
#   - Server returns 503 Service Unavailable
#   - Server returns 504 Gateway Timeout
#
# Failover will NOT occur on:
#   - Client errors (4xx status codes)
#   - Other server responses (5xx except 502/503/504)
#   - Successful responses
#
# Leave empty or omit this variable to disable secondary backend
VITE_SECONDARY_API_URL=

# ============================================================================
# NOTES
# ============================================================================
# - All request properties are preserved during failover:
#   method, headers, body, authentication tokens, query parameters
#
# - For production (Vercel), configure these variables in:
#   Project Settings > Environment Variables
#
# - For local development, use:
#   .env.development (npm run dev)
#   .env.production (npm run build/preview)
#
# - TypeScript types and API are already set up in: src/lib/api.ts
#   No component changes required for failover to work
